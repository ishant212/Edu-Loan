generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  ELIGIBLE
  REJECTED
  NEEDS_VERIFICATION
}

enum LeadCategory {
  HIGH
  MEDIUM
  LOW
}

model Application {
  id                  String              @id @default(uuid())
  fullName            String
  email               String              @unique
  phone               String
  dob                 DateTime?
  city                String?

  educationLevel      String
  targetCourse        String
  universityName      String
  studyCountry        String?
  academicScore       Float

  tuitionFees         Float?
  familyIncome        Float
  existingLoans       Float? @default(0)
  coapplicantIncome   Float?

  loanAmount          Float
  loanDuration        Int?

  applicationStatus   ApplicationStatus @default(PENDING)

  leadScore           Int?
  leadCategory        LeadCategory?

  isDeadLead          Boolean @default(false)

  deadLeadReasons     String[]
  scoringReasons      String[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}